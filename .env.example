# Copia este archivo como ".env" y ajusta los valores

# Postgres
POSTGRES_USER=objetos_user
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=objetos_perdidos
POSTGRES_PORT=5432

# Construido a partir de los valores de arriba (usado por la app)
DATABASE_URL=postgresql://objetos_user:cambia_esta_clave@db:5432/objetos_perdidos

# App
PORT=3000
SESSION_SECRET=cambia_este_secreto_largo_y_aleatorio
NODE_ENV=production

# Adminer (UI web para ver la base de datos)
ADMINER_PORT=8080

# SMTP (verificación de correo al registrarse)
# Usamos Brevo (https://brevo.com): Panel > SMTP & API > SMTP
# IMPORTANTE: la primera vez que el servidor envíe un correo desde una IP nueva,
# Brevo puede bloquearla con el error "Unauthorized IP address". Hay que autorizarla
# en Brevo > Seguridad > Direcciones IP (puede tardar 1-2 minutos en propagarse).
SMTP_HOST=smtp-relay.sendinblue.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Objetos Perdidos
