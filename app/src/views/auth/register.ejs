<div class="max-w-md mx-auto card p-8 mt-6">
  <h1 class="text-2xl font-bold text-brand-800 mb-1">Crear cuenta</h1>
  <p class="text-slate-500 text-sm mb-6">Necesitas una cuenta para publicar objetos perdidos o encontrados.</p>

  <% if (typeof errors !== 'undefined' && errors.length) { %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm">
      <ul class="list-disc list-inside">
        <% errors.forEach(function(e) { %><li><%= e %></li><% }) %>
      </ul>
    </div>
  <% } %>

  <form action="/auth/register" method="POST" class="space-y-4">
    <div>
      <label class="label-field">Nombre completo</label>
      <input type="text" name="name" required maxlength="100" value="<%= values.name || '' %>" class="input-field" />
    </div>
    <div>
      <label class="label-field">Correo electrónico</label>
      <input type="email" name="email" required value="<%= values.email || '' %>" class="input-field" />
    </div>
    <div>
      <label class="label-field">Teléfono (opcional, solo Perú)</label>
      <input type="tel" name="phone" inputmode="numeric" maxlength="9" pattern="\d{9}"
             data-numeric-only data-max-digits="9"
             placeholder="9XXXXXXXX" value="<%= values.phone || '' %>" class="input-field" />
    </div>
    <div>
      <label class="label-field">Contraseña</label>
      <div class="relative">
        <input type="password" id="password" name="password" required minlength="8"
               pattern="(?=.*[A-Za-z])(?=.*\d)(?=.*[^A-Za-z0-9\s]).{8,}"
               title="Mínimo 8 caracteres, incluye letras, números y un carácter especial"
               class="input-field pr-16" />
        <button type="button" data-toggle-password="password"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-brand-600 hover:underline">Mostrar</button>
      </div>
      <p class="text-xs text-slate-400 mt-1">Mínimo 8 caracteres, incluye letras, números y un carácter especial (ej. !@#$%).</p>
    </div>
    <div>
      <label class="label-field">Confirmar contraseña</label>
      <div class="relative">
        <input type="password" id="confirm_password" name="confirm_password" required minlength="8"
               class="input-field pr-16" />
        <button type="button" data-toggle-password="confirm_password"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-brand-600 hover:underline">Mostrar</button>
      </div>
    </div>
    <button type="submit" class="btn-primary w-full">Crear cuenta</button>
  </form>

  <p class="text-sm text-slate-500 mt-5 text-center">
    ¿Ya tienes cuenta? <a href="/auth/login" class="text-brand-700 font-medium hover:underline">Inicia sesión</a>
  </p>
</div>
