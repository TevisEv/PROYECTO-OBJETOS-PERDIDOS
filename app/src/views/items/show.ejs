<a href="/items" class="text-sm text-brand-700 hover:underline mb-4 inline-block">← Volver a la lista</a>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 card overflow-hidden">
    <% if (images.length) { %>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-1 bg-brand-50">
        <% images.forEach(function(img, idx) { %>
          <img src="/uploads/<%= img.filename %>" alt="Foto <%= idx + 1 %>" class="w-full h-48 object-cover <%= idx === 0 ? 'col-span-2 sm:col-span-3 h-72' : '' %>" />
        <% }) %>
      </div>
    <% } else { %>
      <div class="h-60 bg-brand-50 flex items-center justify-center text-brand-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16l5-5a2 2 0 012.8 0l5.2 5.2M14 13l1.7-1.7a2 2 0 012.8 0L21 13M4 19h16a1 1 0 001-1V6a1 1 0 00-1-1H4a1 1 0 00-1 1v12a1 1 0 001 1z" />
        </svg>
      </div>
    <% } %>

    <div class="p-6">
      <div class="flex items-center gap-2 mb-3">
        <% if (item.status === 'recuperado') { %>
          <span class="badge-resolved">Recuperado</span>
        <% } else if (item.type === 'perdido') { %>
          <span class="badge-lost">Perdido</span>
        <% } else { %>
          <span class="badge-found">Encontrado</span>
        <% } %>
        <% if (item.category_name) { %><span class="text-sm text-slate-500"><%= item.category_name %></span><% } %>
      </div>

      <h1 class="text-2xl font-bold text-brand-800 mb-3"><%= item.title %></h1>
      <p class="text-slate-600 whitespace-pre-line mb-6"><%= item.description %></p>

      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <p class="text-slate-400">Ubicación</p>
          <p class="text-slate-700 font-medium">📍 <%= item.location %></p>
        </div>
        <div>
          <p class="text-slate-400">Fecha</p>
          <p class="text-slate-700 font-medium"><%= new Date(item.item_date).toLocaleDateString('es-ES') %></p>
        </div>
        <div>
          <p class="text-slate-400">Publicado por</p>
          <p class="text-slate-700 font-medium"><%= item.owner_name %></p>
        </div>
        <div>
          <p class="text-slate-400">Publicado el</p>
          <p class="text-slate-700 font-medium"><%= new Date(item.created_at).toLocaleDateString('es-ES') %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-4">
    <div class="card p-6">
      <h2 class="font-semibold text-brand-800 mb-3">Información de contacto</h2>
      <% if (item.status === 'recuperado') { %>
        <p class="text-sm text-emerald-700 bg-emerald-50 rounded-lg px-3 py-2">Este objeto ya fue marcado como recuperado.</p>
      <% } else { %>
        <p class="text-sm text-slate-500 mb-3">Contacta a esta persona si tienes información sobre el objeto.</p>
        <ul class="space-y-2 text-sm">
          <li class="text-slate-700"><strong><%= item.contact_name || item.owner_name %></strong></li>
          <% if (item.contact_phone) { %>
            <li><a href="tel:<%= item.contact_phone %>" class="text-brand-700 hover:underline">📞 <%= item.contact_phone %></a></li>
          <% } %>
          <% if (item.contact_email) { %>
            <li><a href="mailto:<%= item.contact_email %>" class="text-brand-700 hover:underline">✉️ <%= item.contact_email %></a></li>
          <% } %>
        </ul>
      <% } %>
    </div>

    <% if (isOwner) { %>
      <div class="card p-6 space-y-2">
        <h2 class="font-semibold text-brand-800 mb-2">Gestionar publicación</h2>
        <a href="/items/<%= item.id %>/edit" class="btn-outline w-full">Editar</a>
        <form action="/items/<%= item.id %>/resolve" method="POST">
          <button type="submit" class="btn-accent w-full">
            <%= item.status === 'activo' ? 'Marcar como recuperado' : 'Marcar como activo' %>
          </button>
        </form>
        <form action="/items/<%= item.id %>?_method=DELETE" method="POST" onsubmit="return confirm('¿Seguro que quieres eliminar esta publicación?');">
          <button type="submit" class="btn-danger w-full">Eliminar</button>
        </form>
      </div>
    <% } %>
  </div>
</div>

<div id="comentarios" class="card p-6 mt-6">
  <h2 class="font-semibold text-brand-800 mb-4">Comentarios y pistas (<%= comments.length %>)</h2>

  <% if (comments.length === 0) { %>
    <p class="text-sm text-slate-400 mb-5">Todavía no hay comentarios. Sé el primero en aportar una pista.</p>
  <% } else { %>
    <ul class="space-y-4 mb-6">
      <% comments.forEach(function(c) { %>
        <li class="flex gap-3">
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-100 text-brand-700 text-xs font-semibold">
            <%= c.author_name.charAt(0).toUpperCase() %>
          </span>
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <p class="text-sm font-medium text-brand-800"><%= c.author_name %></p>
              <p class="text-xs text-slate-400"><%= new Date(c.created_at).toLocaleDateString('es-ES') %></p>
            </div>
            <p class="text-sm text-slate-600"><%= c.body %></p>
          </div>
          <% if (user && user.id === c.user_id) { %>
            <form action="/items/<%= item.id %>/comments/<%= c.id %>?_method=DELETE" method="POST"
                  onsubmit="return confirm('¿Eliminar este comentario?');">
              <button type="submit" class="text-xs text-slate-400 hover:text-red-600">Eliminar</button>
            </form>
          <% } %>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <% if (user) { %>
    <form action="/items/<%= item.id %>/comments" method="POST" class="flex flex-col sm:flex-row gap-2">
      <input type="text" name="body" required minlength="3" maxlength="500"
             placeholder="Ej. Vi algo parecido cerca del parque..." class="input-field flex-1" />
      <button type="submit" class="btn-accent">Comentar</button>
    </form>
  <% } else { %>
    <p class="text-sm text-slate-500 bg-brand-50 rounded-lg px-4 py-3">
      <a href="/auth/login" class="text-brand-700 font-medium hover:underline">Inicia sesión</a>
      para dejar un comentario o una pista sobre este objeto.
    </p>
  <% } %>
</div>
