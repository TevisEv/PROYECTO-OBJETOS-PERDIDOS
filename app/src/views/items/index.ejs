<div class="flex flex-col lg:flex-row gap-6">
  <aside class="lg:w-64 shrink-0">
    <form action="/items" method="GET" class="card p-5 space-y-4">
      <h2 class="font-semibold text-brand-800">Filtrar</h2>

      <div>
        <label class="label-field">Buscar</label>
        <input type="text" name="q" value="<%= filters.q || '' %>" placeholder="Palabra clave" class="input-field" />
      </div>

      <div>
        <label class="label-field">Tipo</label>
        <select name="type" class="input-field">
          <option value="" <%= !filters.type ? 'selected' : '' %>>Todos</option>
          <option value="perdido" <%= filters.type === 'perdido' ? 'selected' : '' %>>Perdido</option>
          <option value="encontrado" <%= filters.type === 'encontrado' ? 'selected' : '' %>>Encontrado</option>
        </select>
      </div>

      <div>
        <label class="label-field">Categoría</label>
        <select name="category" class="input-field">
          <option value="">Todas</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= String(filters.category) === String(c.id) ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label-field">Estado</label>
        <select name="status" class="input-field">
          <option value="" <%= !filters.status ? 'selected' : '' %>>Todos</option>
          <option value="activo" <%= filters.status === 'activo' ? 'selected' : '' %>>Activo</option>
          <option value="recuperado" <%= filters.status === 'recuperado' ? 'selected' : '' %>>Recuperado</option>
        </select>
      </div>

      <div>
        <label class="label-field">Ubicación</label>
        <input type="text" name="location" value="<%= filters.location || '' %>" placeholder="Ej. Centro" class="input-field" />
      </div>

      <button type="submit" class="btn-primary w-full">Aplicar filtros</button>
      <a href="/items" class="block text-center text-sm text-slate-500 hover:underline">Limpiar filtros</a>
    </form>
  </aside>

  <div class="flex-1">
    <div class="flex items-center justify-between mb-5">
      <h1 class="text-xl font-semibold text-brand-800">Objetos publicados <span class="text-slate-400 text-base">(<%= total %>)</span></h1>
    </div>

    <% if (items.length === 0) { %>
      <div class="card p-10 text-center text-slate-500">No se encontraron objetos con esos filtros.</div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% items.forEach(function(item) { %>
          <%- include('../partials/item-card', { item }) %>
        <% }) %>
      </div>
      <%- include('../partials/pagination', { filters, page, totalPages }) %>
    <% } %>
  </div>
</div>
