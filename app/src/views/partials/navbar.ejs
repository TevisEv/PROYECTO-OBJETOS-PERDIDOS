<header class="bg-brand-600 sticky top-0 z-30 shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-semibold text-lg text-white shrink-0">
      <span class="flex items-center justify-center h-9 w-9 rounded-full bg-white/20 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
        </svg>
      </span>
      <span class="hidden sm:inline">Objetos Perdidos</span>
    </a>

    <div class="flex items-center gap-1 text-sm">
      <a href="/items" class="rounded-full px-3 py-1.5 transition-colors <%= currentPath === '/items' ? 'bg-white text-brand-700 font-medium' : 'text-brand-50 hover:bg-white/15' %>">Explorar</a>
      <% if (user) { %>
        <a href="/dashboard" class="rounded-full px-3 py-1.5 transition-colors <%= currentPath === '/dashboard' ? 'bg-white text-brand-700 font-medium' : 'text-brand-50 hover:bg-white/15' %>">Mis publicaciones</a>
      <% } %>
    </div>

    <div class="flex items-center gap-2 shrink-0">
      <% if (user) { %>
        <a href="/items/new" class="btn-accent !py-2">+ Publicar</a>
        <form action="/auth/logout" method="POST">
          <button type="submit" class="rounded-lg px-4 py-2 text-sm font-medium text-white border border-white/40 hover:bg-white/15 transition-colors">Salir</button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="rounded-lg px-4 py-2 text-sm font-medium text-white border border-white/40 hover:bg-white/15 transition-colors">Iniciar sesión</a>
        <a href="/auth/register" class="btn-accent !py-2">Crear cuenta</a>
      <% } %>
    </div>
  </nav>
</header>
