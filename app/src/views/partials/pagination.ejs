<% if (totalPages > 1) { %>
  <% const baseParams = Object.fromEntries(Object.entries(filters || {}).filter(([k, v]) => v)); %>
  <div class="flex items-center justify-center gap-2 mt-8">
    <% for (let p = 1; p <= totalPages; p++) { %>
      <a href="?<%= new URLSearchParams({ ...baseParams, page: p }).toString() %>"
         class="px-3 py-1.5 rounded-lg text-sm <%= p === page ? 'bg-brand-700 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-100' %>">
        <%= p %>
      </a>
    <% } %>
  </div>
<% } %>
